{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "scripts/**/*.js",
    "scripts/**/*.ts",
    "test/**/*.js",
    "test/**/*.ts",
    "vitest.config.js"
  ],
  "exclude": ["node_modules", "src/data_old/**"]
}
